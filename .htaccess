# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# GamTech Admin Panel
RewriteRule ^admin-panel/?$ /gs-panel.php?key=gamtech2026admin [L,QSA]
RewriteRule ^admin/?$ /gs-panel.php?key=gamtech2026admin [L,QSA]

RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
# END WordPress
